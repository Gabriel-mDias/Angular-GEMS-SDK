{
  "name": "@gabriel-mdias/angular-gems-sdk",
  "version": "1.1.0",
  "description": "Kit de desenvolvimento Angular para projetos G&Ms — componentes, serviços e theming configurável.",
  "license": "MIT",
  "author": "Gabriel Magalhães",
  "homepage": "https://github.com/Gabriel-mDias/Angular-GEMS-SDK#readme",
  "bugs": {
    "url": "https://github.com/Gabriel-mDias/Angular-GEMS-SDK/issues"
  },
  "keywords": [
    "angular",
    "angular-library",
    "components",
    "ui",
    "sdk",
    "design-system",
    "theming",
    "keycloak",
    "gems"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gabriel-mDias/Angular-GEMS-SDK.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@angular/common": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@fortawesome/fontawesome-free": "^6.0.0 || ^7.0.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "keycloak-angular": {
      "optional": true
    },
    "@fortawesome/fontawesome-free": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "keycloak-angular": "^16.0.0"
  },
  "dependencies": {
    "sweetalert2": "^11.0.0",
    "tslib": "^2.3.0"
  },
  "sideEffects": false,
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./index.d.ts",
      "default": "./fesm2022/gabriel-mdias-angular-gems-sdk.mjs"
    },
    "./styles.css": {
      "style": "./src/lib/styles/gems-global.css",
      "default": "./src/lib/styles/gems-global.css"
    },
    "./*": "./*"
  }
}
